# Copy this file to ".env" and fill in your own values.
# NEVER commit the real .env file - it is gitignored.
# This .example file must only ever contain PLACEHOLDERS, never real secrets.

# Server
PORT=5000

# MongoDB Atlas connection string (from Atlas dashboard -> Connect -> Drivers)
# Preferred: the short "mongodb+srv://" form (works on most networks & on Render).
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/jobtracker?appName=<app-name>
#
# Fallback: if the srv form fails with "querySrv/queryTxt ECONNREFUSED/ETIMEOUT"
# (some networks block the SRV/TXT DNS records the +srv form needs), use the
# standard form below instead. It lists the shards directly so no SRV/TXT DNS
# lookup is required (Atlas -> Connect -> Drivers -> older driver version):
# MONGO_URI=mongodb://<username>:<password>@<shard-00>:27017,<shard-01>:27017,<shard-02>:27017/jobtracker?ssl=true&replicaSet=<replica-set-name>&authSource=admin&retryWrites=true&w=majority

# Secret used to sign JWT tokens. Use a long random string.
JWT_SECRET=replace_with_a_long_random_secret_string

# OpenRouter API key (https://openrouter.ai -> Keys). Used in Phase 5.
OPENROUTER_API_KEY=sk-or-your-key-here

# Which model(s) the AI matcher uses. Keep them FREE models (ending ":free") so
# the app costs nothing. Optional - the code has a sensible default list. You can
# give a COMMA-SEPARATED list: they're tried in order and the first one that
# answers is used (the free tier rate-limits individual models, so a list is more
# reliable than a single model). Browse free models: https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-coder:free

# Frontend origin allowed by CORS (set to your Vercel URL in production)
CLIENT_URL=http://localhost:5173
