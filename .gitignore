# Dependencies
node_modules/
*/node_modules/

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.*.local
*/.env

# Build output
dist/
build/
*/dist/
*/build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# ...but DO track our hand-written project journal in LOGS/ (learning + failures
# notes). The generic "logs/" rule above otherwise hides it on case-insensitive
# filesystems like Windows.
!LOGS/
!LOGS/**

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Misc
coverage/
.cache/

# Private notes — local only, never pushed (personal prep material)
prep/

# AI assistant project brief — kept local, not part of the public repo
CLAUDE.md
